# TallyDekho Backend — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=30d

# Database
DB_PATH=./data/tallydekho.db

# CORS — allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# WhatsApp OTP (Cronberry WABA)
CRONBERRY_URL=https://crmapi.cronberry.com/api/v1/messages
CRONBERRY_TOKEN=your_cronberry_bearer_token_here
CRONBERRY_TEMPLATE=otp_international

# Internal API secret (for /ingest/complete-notify)
INTERNAL_SECRET=generate_a_random_secret_here
